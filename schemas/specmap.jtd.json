{
    "metadata": {
        "description": "Wire format for the canonical `specmap.json` index — the derived, deterministic, committed spec<->code traceability artefact regenerated by `cargo xtask specmap` and gated by `--check` (PROP-014 §2.5). Source of truth for `crates/vibe-wire/src/generated/specmap/`.",
        "rustOptions": {
            "package": "vibe_wire::specmap"
        }
    },
    "definitions": {
        "spec_unit": {
            "metadata": {
                "description": "One spec unit: the span from an anchored heading to the next same-or-higher heading (PROP-014 §2.1-2.2). Units without a kind/revision line are legacy-unmarked and carry only the inventory fields."
            },
            "properties": {
                "uri": {
                    "type": "string",
                    "metadata": {
                        "description": "Canonical address: `spec://<package>/<doc-path>#<anchor>`."
                    }
                },
                "doc_path": {
                    "type": "string",
                    "metadata": {
                        "description": "Forward-slash repo-relative markdown path."
                    }
                },
                "anchor": {
                    "type": "string"
                },
                "heading": {
                    "type": "string",
                    "metadata": {
                        "description": "Heading text without the `{#anchor}` suffix."
                    }
                },
                "content_hash": {
                    "type": "string",
                    "metadata": {
                        "description": "`sha256:<hex>` over the unit span (heading line + body), line endings normalised to LF."
                    }
                },
                "line": {
                    "type": "uint32",
                    "metadata": {
                        "description": "1-based line of the heading. Derived decoration — volatile across edits, deterministic per tree (PROP-014 §2.3)."
                    }
                }
            },
            "optionalProperties": {
                "kind": {
                    "enum": ["prop", "req", "design", "guide"],
                    "metadata": {
                        "description": "From the unit's kind line (GUIDE-SPEC-AUTHORING §3); absent on legacy-unmarked units."
                    }
                },
                "revision": {
                    "type": "uint32",
                    "metadata": {
                        "description": "Author-asserted semantic revision `rN`."
                    }
                },
                "status": {
                    "enum": ["planned", "disputed"],
                    "metadata": {
                        "description": "Lifecycle status (brownfield amendment); absent = ratified."
                    }
                },
                "disputes": {
                    "type": "string",
                    "metadata": {
                        "description": "For `disputed` status: the other anchor of the conflicts_with pair."
                    }
                }
            }
        },
        "code_item": {
            "metadata": {
                "description": "A tagged code item (fn, struct, enum, trait, impl, mod). Only items carrying at least one edge appear; the full-orphan inventory is a later-phase table."
            },
            "properties": {
                "symbol": {
                    "type": "string",
                    "metadata": {
                        "description": "Module-qualified path, e.g. `vibe_resolver::conditional::ConditionalPredicate::parse`."
                    }
                },
                "item_kind": {
                    "type": "string"
                },
                "crate_name": {
                    "type": "string"
                },
                "file": {
                    "type": "string",
                    "metadata": {
                        "description": "Forward-slash repo-relative source path."
                    }
                },
                "line": {
                    "type": "uint32"
                }
            }
        },
        "edge": {
            "metadata": {
                "description": "One typed, directed edge `(code item) --verb--> (spec unit)` (PROP-014 §2.4)."
            },
            "properties": {
                "from_symbol": {
                    "type": "string"
                },
                "verb": {
                    "enum": ["implements", "verifies", "documents", "deviates", "informs"]
                },
                "uri": {
                    "type": "string"
                },
                "provenance": {
                    "enum": ["authored", "generated", "proposed"]
                },
                "file": {
                    "type": "string"
                },
                "line": {
                    "type": "uint32"
                }
            },
            "optionalProperties": {
                "pinned_r": {
                    "type": "uint32",
                    "metadata": {
                        "description": "The revision the edge is pinned to (`r = N`); suspect detection compares it to the unit's current revision."
                    }
                },
                "reason": {
                    "type": "string",
                    "metadata": {
                        "description": "Mandatory for `deviates` — validated by the grammar, carried verbatim here."
                    }
                }
            }
        },
        "warning": {
            "metadata": {
                "description": "Non-fatal indexer findings (duplicate anchors, malformed kind lines, unparseable sources). B5: the indexer degrades, never errors, outside the migrated frontier."
            },
            "properties": {
                "code": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                },
                "file": {
                    "type": "string"
                },
                "line": {
                    "type": "uint32"
                }
            }
        }
    },
    "properties": {
        "schema": {
            "type": "uint32"
        },
        "spec_units": {
            "elements": {
                "ref": "spec_unit"
            }
        },
        "code_items": {
            "elements": {
                "ref": "code_item"
            }
        },
        "edges": {
            "elements": {
                "ref": "edge"
            }
        },
        "warnings": {
            "elements": {
                "ref": "warning"
            }
        }
    }
}
